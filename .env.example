# Supabase — Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://kkhhslzfhtsyfgjegchd.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=
# Database password — Settings → Database (optional)
SUPABASE_DB_PASSWORD=

# Anthropic (server-only) — used by the agent route. Do NOT prefix with EXPO_PUBLIC_.
ANTHROPIC_API_KEY=sk-ant-api03-...

# LogMeal API (server-only). Do NOT prefix with EXPO_PUBLIC_.
LogMealAPI=

# OpenAI (server-only) — used to mint Realtime voice sessions. Do NOT prefix.
OPENAI_API_KEY=sk-proj-...

# Server-only token for the Apify Google Places actor.
# DO NOT prefix with EXPO_PUBLIC_ — it must not ship in the mobile bundle.
APIFY_TOKEN=apify_api_...

# Google Calendar OAuth (server exchange + client PKCE)
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# OAuth redirect URI. Localhost-only dev: must exactly match one of the URIs
# whitelisted on the Web OAuth client in Google Cloud.
EXPO_PUBLIC_GOOGLE_OAUTH_REDIRECT=http://localhost:8081/oauth

# Shared secret for the proactive notification cron route (POST /api/cron/proactive-tick)
# We are in a hackathon so we need to skipp this
CRON_SECRET=

# Optional base URL for Expo Router API routes when running on a physical device
# or emulator where Metro's host is not reachable via a relative URL.
# Example: http://192.168.1.10:8081
EXPO_PUBLIC_API_URL=
