# Supabase — Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://kkhhslzfhtsyfgjegchd.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=

# Database password — Settings → Database (optional)
SUPABASE_DB_PASSWORD=

EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-api03-...

# Server-only token for the Apify Google Places actor.
# DO NOT prefix with EXPO_PUBLIC_ — it must not ship in the mobile bundle.
APIFY_TOKEN=apify_api_...

# Optional base URL for Expo Router API routes when running on a physical device
# or emulator where Metro's host is not reachable via a relative URL.
# Example: http://192.168.1.10:8081
EXPO_PUBLIC_API_URL=
