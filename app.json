{
  "expo": {
    "name": "baseplate-mobile",
    "slug": "baseplate-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.baseplate.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.baseplate.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "scheme": "baseplate-mobile",
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Calorie-AI to use your camera to scan meals.",
          "photosPermission": "Allow Calorie-AI to access your photos to analyze meal images."
        }
      ]
    ]
  }
}
